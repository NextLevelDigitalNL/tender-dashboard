{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/opdrachten", "dest": "api/index.py" },
    { "src": "/api/overige-opdrachten", "dest": "api/index.py" },
    { "src": "/", "dest": "public/dashboard.html" },
    { "src": "/dashboard", "dest": "public/dashboard.html" },
    { "src": "/tenders", "dest": "public/dashboard.html" },
    { "src": "/overige-opdrachten", "dest": "public/overige-opdrachten.html" }
  ]
}
